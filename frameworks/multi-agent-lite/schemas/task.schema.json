{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "type": "object",
  "required": ["task_id", "title", "goal", "status", "owner", "task_type", "priority", "acceptance"],
  "properties": {
    "task_id": { "type": "string" },
    "title": { "type": "string" },
    "goal": { "type": "string" },
    "status": { "type": "string", "enum": ["NEW", "PLAN", "READY", "EXECUTING", "REVIEW", "DONE", "BLOCKED", "FAILED", "CANCELLED"] },
    "owner": { "type": "string" },
    "task_type": { "type": "string", "enum": ["code", "framework_design", "automation", "fact_lookup", "choice_answering", "config_authoring", "path_lookup", "general"] },
    "priority": { "type": "string", "enum": ["low", "normal", "high", "critical"] },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "context_refs": { "type": "array", "items": { "type": "string" } },
    "subtasks": { "type": "array", "items": { "type": "object" } },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "deliverable_candidates": { "type": "array", "items": { "type": "string" } },
    "delivery_changes": { "type": "array", "items": { "type": "string" } },
    "delivery_risks": { "type": "array", "items": { "type": "string" } },
    "delivery_evidence": { "type": "array", "items": { "type": "object" } },
    "delivery_internal_evidence": { "type": "array", "items": { "type": "object" } },
    "delivery_summary": { "type": "string" },
    "delivery_status": { "type": "string", "enum": ["not_started", "assembled", "delivered", "not_delivered", "unknown"] },
    "planning_profile": { "type": "string", "enum": ["direct_review", "research_execute_review", "research_execute_review_strict"] },
    "orchestration_mode": { "type": "string", "enum": ["full", "compact", "minimal"] },
    "execution_budget": { "type": "object" },
    "sendback_count": { "type": "integer", "minimum": 0 },
    "degrade_history": { "type": "array", "items": { "type": "object" } },
    "writeback_hint": { "type": "object" },
    "task_result_packet": { "type": ["object", "null"] },
    "history": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
