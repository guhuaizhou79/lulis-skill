{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "type": "object",
  "required": ["task_id", "title", "goal", "status", "owner", "task_type", "priority", "acceptance"],
  "properties": {
    "task_id": { "type": "string" },
    "title": { "type": "string" },
    "goal": { "type": "string" },
    "status": { "type": "string", "enum": ["NEW", "PLAN", "READY", "EXECUTING", "REVIEW", "DONE", "BLOCKED", "FAILED", "CANCELLED"] },
    "owner": { "type": "string" },
    "task_type": { "type": "string" },
    "priority": { "type": "string", "enum": ["low", "normal", "high", "critical"] },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "context_refs": { "type": "array", "items": { "type": "string" } },
    "subtasks": { "type": "array", "items": { "type": "object" } },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "delivery_summary": { "type": "string" },
    "delivery_status": { "type": "string", "enum": ["not_started", "assembled", "delivered", "not_delivered", "unknown"] },
    "planning_profile": { "type": "string", "enum": ["direct_review", "research_execute_review", "research_execute_review_strict"] },
    "history": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
